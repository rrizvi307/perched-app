# Copy this file to .env.local and fill in your actual API keys
# .env.local is gitignored and won't be committed

# Google Maps (for iOS/Android native maps)
GOOGLE_MAPS_API_KEY=

# Firebase Configuration
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# External APIs (for spot intelligence)
OPENAI_API_KEY=
YELP_API_KEY=
FOURSQUARE_API_KEY=

# Feature Flags
INTEL_V1_ENABLED=false

# Premium (RevenueCat)
REVENUECAT_PUBLIC_KEY=

# App Store submission gate
# Set these before running `npm run preflight` for the final candidate.
ENV=production
SMOKE_TEST_EMAIL=
SMOKE_TEST_PASSWORD=
REQUIRE_AUTH_SMOKE_CHECK=true
REQUIRE_PLACE_PROVIDER_SMOKE_CHECK=true
REQUIRE_PROXY_ONLY_PARITY=true
REQUIRE_POST_DEPLOY_SMOKE_CHECK=true
FORCE_PROXY_ONLY=true
EXPO_PUBLIC_FORCE_PROXY_ONLY=true
