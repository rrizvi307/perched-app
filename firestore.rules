rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    function hasPostingAccess() {
      return isAdmin() ||
        isVerified() ||
        (isAuthenticated() && request.auth.token.phone_number != null);
    }

    function isStringList(value) {
      return !(value is list) || value.size() == 0 || value[0] is string;
    }

    function socialGraphExists(userId) {
      return exists(/databases/$(database)/documents/socialGraph/$(userId));
    }

    function socialGraphData(userId) {
      return get(/databases/$(database)/documents/socialGraph/$(userId)).data;
    }

    function hasFriendAccess(userId) {
      return socialGraphExists(userId) &&
        socialGraphData(userId).friends is list &&
        socialGraphData(userId).friends.hasAny([request.auth.uid]);
    }

    function hasCloseFriendAccess(userId) {
      return socialGraphExists(userId) &&
        socialGraphData(userId).closeFriends is list &&
        socialGraphData(userId).closeFriends.hasAny([request.auth.uid]);
    }

    function canReadCheckinData(checkinData) {
      return isAuthenticated() && (
        checkinData.userId == request.auth.uid ||
        checkinData.visibility == 'public' ||
        (
          checkinData.visibility == 'friends' && hasFriendAccess(checkinData.userId)
        ) ||
        (
          checkinData.visibility == 'close' && hasCloseFriendAccess(checkinData.userId)
        )
      );
    }

    function canReadCheckinById(checkinId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/checkins/$(checkinId)) &&
        canReadCheckinData(get(/databases/$(database)/documents/checkins/$(checkinId)).data);
    }

    match /publicProfiles/{userId} {
      allow read: if isAuthenticated();

      allow create: if isOwner(userId) &&
                      request.resource.data.keys().hasOnly([
                        'name',
                        'nameLower',
                        'city',
                        'campus',
                        'campusOrCity',
                        'campusType',
                        'handle',
                        'photoUrl',
                        'avatarUrl',
                        'coffeeIntents',
                        'ambiancePreference',
                        'referralCode',
                        'createdAt',
                        'updatedAt'
                      ]);

      allow update: if isOwner(userId) &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                        'name',
                        'nameLower',
                        'city',
                        'campus',
                        'campusOrCity',
                        'campusType',
                        'handle',
                        'photoUrl',
                        'avatarUrl',
                        'coffeeIntents',
                        'ambiancePreference',
                        'referralCode',
                        'updatedAt'
                      ]);

      allow delete: if isOwner(userId) || isAdmin();
    }

    match /socialGraph/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId) &&
                      request.resource.data.keys().hasOnly([
                        'friends',
                        'closeFriends',
                        'blocked',
                        'createdAt',
                        'updatedAt'
                      ]) &&
                      isStringList(request.resource.data.friends) &&
                      isStringList(request.resource.data.closeFriends) &&
                      isStringList(request.resource.data.blocked);

      allow update: if false;
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Raw owner/admin account doc
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) &&
                              request.resource.data.keys().hasOnly([
                                'createdAt',
                                'updatedAt',
                                'migrationVersion'
                              ]);
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /userPrivate/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAuthenticated() &&
                              request.auth.uid == userId &&
                              !request.resource.data.keys().hasAny([
                                'friends',
                                'closeFriends',
                                'blocked',
                                'name',
                                'nameLower',
                                'handle',
                                'city',
                                'campus',
                                'campusOrCity',
                                'campusType',
                                'photoUrl',
                                'avatarUrl',
                                'coffeeIntents',
                                'ambiancePreference'
                              ]);
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Check-ins collection
    match /checkins/{checkinId} {
      // Read access based on visibility
      allow read: if canReadCheckinData(resource.data);

      // Check-ins are created via Cloud Functions so posting eligibility and rate limits
      // are enforced server-side instead of trusting client writes.
      allow create: if false;

      // Only owner can update their check-ins
      allow update: if isOwner(resource.data.userId) &&
                      // Prevent changing userId
                      request.resource.data.userId == resource.data.userId;

      // Owner or admin can delete
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Friend requests collection
    match /friendRequests/{requestId} {
      // Users can read requests involving them (resource == null means doc doesn't exist — allow so existence checks work)
      allow read: if isAuthenticated() && (
        resource == null ||
        resource.data.fromId == request.auth.uid ||
        resource.data.toId == request.auth.uid
      );

      // Users can create friend requests (from themselves)
      allow create: if isAuthenticated() &&
                      request.resource.data.fromId == request.auth.uid &&
                      request.resource.data.toId != request.auth.uid &&
                      request.resource.data.status == 'pending' &&
                      request.resource.data.keys().hasAll(['fromId', 'toId', 'status', 'createdAt']) &&
                      request.resource.data.keys().hasOnly(['fromId', 'toId', 'status', 'createdAt', 'respondedAt']);

      // Users can update requests they're involved in (to accept/reject)
      allow update: if isAuthenticated() && (
        resource.data.fromId == request.auth.uid ||
        resource.data.toId == request.auth.uid
      ) &&
      request.resource.data.fromId == resource.data.fromId &&
      request.resource.data.toId == resource.data.toId &&
      request.resource.data.createdAt == resource.data.createdAt &&
      request.resource.data.status in ['pending', 'accepted', 'declined'] &&
      request.resource.data.keys().hasOnly(['fromId', 'toId', 'status', 'createdAt', 'respondedAt']);

      // Users can delete their own requests
      allow delete: if isAuthenticated() && (
        resource.data.fromId == request.auth.uid ||
        resource.data.toId == request.auth.uid
      );
    }

    // Reports collection
    match /reports/{reportId} {
      // Only admins can read reports
      allow read: if isAdmin() || (isAuthenticated() && resource.data.reporterId == request.auth.uid);

      // Any authenticated user can create a report
      allow create: if isAuthenticated() &&
                      request.resource.data.reporterId == request.auth.uid &&
                      request.resource.data.keys().hasAll(['reporterId', 'reason', 'createdAt']) &&
                      request.resource.data.keys().hasAny(['reportedUserId', 'reportedId', 'checkinId']);

      // Only admins can update (to change status)
      allow update: if isAdmin();

      // Only admins can delete
      allow delete: if isAdmin();
    }

    // Admins collection
    match /admins/{userId} {
      // Only admins can read
      allow read: if isAdmin();

      // No client-side creation/updates/deletes
      allow write: if false;
    }

    // Event logs (analytics)
    match /eventLogs/{logId} {
      // No read access for clients
      allow read: if false;

      // Authenticated users can write their own events
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;

      // No updates or deletes
      allow update, delete: if false;
    }

    match /checkinWriteGuards/{userId} {
      allow read, write: if false;
    }

    // Spot aggregates used by explore, spot detail, and recommendations.
    // These docs are server-managed; clients may read but not mutate them.
    match /spots/{spotId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // Place events/tags (for trending/ranking)
    match /placeEvents/{eventId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;

      allow update, delete: if false;
    }

    match /placeTags/{tagId} {
      allow read: if isAuthenticated();

      // Server-owned aggregate (Admin SDK bypasses rules).
      allow create, update: if false;

      allow delete: if false;
    }

    // Active aggregate + per-user vote collections used by current mobile clients.
    match /place_tags/{tagId} {
      allow read: if isAuthenticated();
      allow create, update: if false;
      allow delete: if false;
    }

    match /place_tag_votes/{voteId} {
      allow read: if isAuthenticated() &&
                    (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.placeKey is string;
      allow update: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid &&
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.placeKey == resource.data.placeKey;
      allow delete: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid;
    }

    // Notifications
    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isAuthenticated() &&
                    resource.data.userId == request.auth.uid;

      // Users can mark their own notifications as read
      allow update: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid &&
                      // Only allow updating 'read' field
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);

      // System/Cloud Functions can create notifications
      allow create: if false;

      // Users can delete their own notifications
      allow delete: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid;
    }

    // Push tokens for notifications
    match /pushTokens/{tokenId} {
      // Users can read their own tokens
      allow read: if isAuthenticated() &&
                    resource.data.userId == request.auth.uid;

      // Users can create/update their own tokens
      allow create, update: if isAuthenticated() &&
                              tokenId == request.auth.uid &&
                              request.resource.data.userId == request.auth.uid &&
                              request.resource.data.keys().hasOnly(['userId', 'token', 'updatedAt']) &&
                              request.resource.data.token is string &&
                              request.resource.data.token.size() > 0 &&
                              request.resource.data.token.size() < 512;

      // Users can delete their own tokens
      allow delete: if isAuthenticated() &&
                      tokenId == request.auth.uid &&
                      resource.data.userId == request.auth.uid;
    }

    // Reactions collection (for check-in reactions)
    match /reactions/{reactionId} {
      allow read: if canReadCheckinById(resource.data.checkinId);

      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.keys().hasAll(['checkinId', 'type', 'userId', 'createdAt']) &&
                      canReadCheckinById(request.resource.data.checkinId);

      allow delete: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid &&
                      canReadCheckinById(resource.data.checkinId);

      allow update: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid &&
                      canReadCheckinById(resource.data.checkinId) &&
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.checkinId == resource.data.checkinId &&
                      request.resource.data.keys().hasOnly([
                        'id',
                        'checkinId',
                        'userId',
                        'userName',
                        'userHandle',
                        'type',
                        'createdAt',
                        'updatedAt'
                      ]);
    }

    // Comments collection (for check-in comments)
    match /comments/{commentId} {
      allow read: if canReadCheckinById(resource.data.checkinId);

      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.keys().hasAll(['checkinId', 'text', 'userId', 'createdAt']) &&
                      canReadCheckinById(request.resource.data.checkinId);

      allow update: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid &&
                      canReadCheckinById(resource.data.checkinId) &&
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.checkinId == resource.data.checkinId &&
                      request.resource.data.keys().hasOnly([
                        'id',
                        'checkinId',
                        'userId',
                        'userName',
                        'userHandle',
                        'text',
                        'createdAt',
                        'updatedAt'
                      ]);

      allow delete: if isAuthenticated() &&
                      resource.data.userId == request.auth.uid &&
                      canReadCheckinById(resource.data.checkinId);
    }

    // User stats collection (for gamification)
    match /userStats/{userId} {
      allow read: if isAuthenticated() &&
                    (request.auth.uid == userId || isAdmin());
      allow create, update: if false;
      allow delete: if false;
    }

    // Achievements collection (for unlocked achievements)
    match /achievements/{achievementId} {
      allow read: if isAuthenticated() &&
                    (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    // Referral signup tracking (write by newly created user, process server-side).
    match /referrals/{referralId} {
      allow read: if isAuthenticated() &&
                    (resource.data.newUserId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
                      request.resource.data.newUserId == request.auth.uid &&
                      request.resource.data.referralCode is string &&
                      request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    // Business ownership claims
    match /businessSpots/{businessSpotId} {
      allow read: if isAuthenticated() &&
                    (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
                      request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
                              (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // Promotions for business spots
    match /promotions/{promotionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                      request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
                              (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /promotionRedemptions/{redemptionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /checkinResponses/{responseId} {
      allow read: if isAuthenticated() &&
                    (resource.data.userId == request.auth.uid ||
                     resource.data.ownerId == request.auth.uid ||
                     isAdmin());
      allow create: if isAuthenticated() &&
                      request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
                              (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // Partner program
    match /partners/{partnerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                      request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
                              (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /loyaltyCards/{cardId} {
      allow read: if isAuthenticated() &&
                    (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
                      (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if false;
    }

    match /loyaltyRedemptions/{redemptionId} {
      allow read: if isAuthenticated() &&
                    (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /partnerEvents/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                      request.resource.data.keys().hasAll(['partnerId']) &&
                      exists(/databases/$(database)/documents/partners/$(request.resource.data.partnerId)) &&
                      get(/databases/$(database)/documents/partners/$(request.resource.data.partnerId)).data.ownerId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
                              exists(/databases/$(database)/documents/partners/$(resource.data.partnerId)) &&
                              get(/databases/$(database)/documents/partners/$(resource.data.partnerId)).data.ownerId == request.auth.uid;
    }

    match /equipmentSponsorships/{sponsorshipId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                      request.resource.data.keys().hasAll(['partnerId']) &&
                      exists(/databases/$(database)/documents/partners/$(request.resource.data.partnerId)) &&
                      get(/databases/$(database)/documents/partners/$(request.resource.data.partnerId)).data.ownerId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
                              exists(/databases/$(database)/documents/partners/$(resource.data.partnerId)) &&
                              get(/databases/$(database)/documents/partners/$(resource.data.partnerId)).data.ownerId == request.auth.uid;
    }

    // Trust & safety collections
    match /blockedUsers/{blockId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /safetySettings/{userId} {
      allow read: if isAuthenticated() &&
                    (request.auth.uid == userId || isAdmin());
      allow create, update: if isAuthenticated() &&
                              request.auth.uid == userId &&
                              request.resource.data.userId == userId &&
                              !request.resource.data.keys().hasAny(['blockedUsers']);
      allow delete: if false;
    }

    match /userWarnings/{warningId} {
      allow read: if isAuthenticated() &&
                    (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /flaggedContent/{contentId} {
      allow read: if isAuthenticated() &&
                    (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Performance metrics (write-only from clients, read by admins)
    match /performanceMetrics/{metricId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Gamification profiles
    match /gamification/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if false;
    }

    // Weekly early-adopter raffle entries
    match /weeklyRaffleEntries/{entryId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create, update, delete: if false;
    }

    // B2B keys/logs must be server-managed
    match /apiKeys/{apiKeyId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /apiUsageLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
