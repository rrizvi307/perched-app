rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isVerified() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return request.auth != null &&
        (request.auth.token.admin == true || request.auth.token.role == "admin");
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isValidSize() {
      // Max 10MB for images
      return request.resource.size < 10 * 1024 * 1024;
    }

    function isValidCheckinVisibility(value) {
      return value in ['public', 'friends', 'close'];
    }

    function hasFriendAccess(userId) {
      return firestore.exists(/databases/(default)/documents/users/$(userId)) &&
        firestore.get(/databases/(default)/documents/users/$(userId)).data.friends.hasAny([request.auth.uid]);
    }

    function hasCloseFriendAccess(userId) {
      return firestore.exists(/databases/(default)/documents/users/$(userId)) &&
        firestore.get(/databases/(default)/documents/users/$(userId)).data.closeFriends.hasAny([request.auth.uid]);
    }

    function hasValidCheckinMetadata(userId) {
      return request.resource.metadata.ownerId == userId &&
        request.resource.metadata.mediaKind == 'checkin' &&
        isValidCheckinVisibility(request.resource.metadata.visibility);
    }

    function canReadCheckinMedia(userId) {
      return isOwner(userId) || (
        isAuthenticated() &&
        resource.metadata.ownerId == userId &&
        resource.metadata.mediaKind == 'checkin' &&
        (
          resource.metadata.visibility == 'public' ||
          (resource.metadata.visibility == 'friends' && hasFriendAccess(userId)) ||
          (resource.metadata.visibility == 'close' && hasCloseFriendAccess(userId))
        )
      );
    }

    // Check-in photos
    match /checkins/{userId}/{filename} {
      allow read: if canReadCheckinMedia(userId);

      allow create: if isOwner(userId) &&
                      isValidImage() &&
                      isValidSize() &&
                      hasValidCheckinMetadata(userId);

      allow update: if isOwner(userId) &&
                      isValidImage() &&
                      isValidSize() &&
                      hasValidCheckinMetadata(userId);

      allow delete: if isOwner(userId) || isAdmin();
    }

    // Profile photos
    match /profiles/{userId}/{filename} {
      // Anyone can read profile photos
      allow read: if isAuthenticated();

      // Only the owner can upload their profile photo
      allow create: if isOwner(userId) &&
                      isValidImage() &&
                      isValidSize();

      // Only owner can update
      allow update: if isOwner(userId) &&
                      isValidImage() &&
                      isValidSize();

      // Only owner can delete
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Story/share images (temporary exports)
    match /stories/{userId}/{filename} {
      // Stories are public once created
      allow read: if isAuthenticated();

      // Only owner can create story images
      allow create: if isOwner(userId) &&
                      isValidImage() &&
                      isValidSize();

      // Owner can delete
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Default deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
