{
  "name": "perched-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "RCT_METRO_PORT=8081 expo run:ios --port 8081",
    "web": "expo start --web",
    "lint": "expo lint --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "build:ios:export": "npm exec -- expo export --platform ios --clear --output-dir .expo-export",
    "build:mobile": "npm run build:ios:export",
    "check:app": "npm run typecheck && npm run lint && npm run test:unit -- --runInBand && npm run build:ios:export",
    "check:all": "npm run check:app && npm --prefix functions run build && npm --prefix functions test -- --runInBand",
    "check:security": "npm run test:rules",
    "preflight": "node ./scripts/release-preflight.js",
    "preflight:release": "node ./scripts/release-preflight.js",
    "appstore:preflight": "node ./scripts/appstore-review-preflight.js",
    "migrate:user-documents:split": "node ./scripts/migrate-user-document-split.js",
    "verify:user-documents:split": "node ./scripts/verify-user-document-split.js",
    "post-deploy:smoke-check": "node ./scripts/post-deploy-smoke-check.js",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:rules": "firebase deploy --only firestore:rules,storage",
    "deploy:production": "npm run deploy:functions && npm run migrate:user-documents:split -- --apply && npm run verify:user-documents:split && npm run deploy:rules && npm run post-deploy:smoke-check && npm run build:mobile",
    "migrate:social-graph:legacy": "node ./scripts/migrate-legacy-social-graph.js",
    "migrate:sensitive-data:legacy": "node ./scripts/migrate-legacy-sensitive-data.js",
    "demo:seed:cloud": "node ./scripts/seed-cloud-demo-feed.js",
    "demo:audit": "node ./scripts/audit-demo-photos.js",
    "test": "npm run test:unit",
    "test:unit": "jest --testPathIgnorePatterns __tests__/securityRules.test.ts",
    "test:rules": "firebase emulators:exec --project demo-perched-rules --only firestore,storage \"npx jest --runInBand __tests__/securityRules.test.ts\"",
    "test:watch": "jest --watch --testPathIgnorePatterns __tests__/securityRules.test.ts",
    "test:coverage": "jest --coverage --testPathIgnorePatterns __tests__/securityRules.test.ts",
    "test:ci": "jest --ci --coverage --maxWorkers=2 --testPathIgnorePatterns __tests__/securityRules.test.ts"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.3.0",
    "@expo/cli": "^55.0.14",
    "@expo/vector-icons": "^15.0.3",
    "@google-cloud/secret-manager": "^6.1.1",
    "@react-google-maps/api": "^2.20.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^11.5.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "^7.11.0",
    "@types/joi": "^17.2.2",
    "@types/winston": "^2.4.4",
    "expo": "^54.0.33",
    "expo-asset": "^12.0.12",
    "expo-blur": "^15.0.8",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "^8.0.8",
    "expo-constants": "~18.0.12",
    "expo-contacts": "~15.0.11",
    "expo-device": "^8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "^14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-localization": "^17.0.8",
    "expo-location": "~19.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "^0.32.16",
    "expo-router": "~6.0.21",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "^9.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "^29.0.16",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.7.0",
    "firebase-functions": "^7.0.5",
    "joi": "^18.0.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.2",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "victory-native": "^36.6.8",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@testing-library/react-native": "^12.5.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "firebase-admin": "^13.6.1",
    "firebase-tools": "^15.8.0",
    "geofire-common": "^6.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=24.11.0 <25",
    "npm": ">=10"
  },
  "overrides": {
    "fast-xml-parser": "5.4.1",
    "minimatch": "10.2.4",
    "@tootallnate/once": "3.0.1",
    "flatted": "3.4.0"
  },
  "private": true
}
